-- Talon Lonte
pcall(function()
    game.CoreGui:FindFirstChild("MaintenanceGUI"):Destroy()
end)

-- Rexz Gui
local gui = Instance.new("ScreenGui")
gui.Name = "MaintenanceGUI"
gui.Parent = game.CoreGui
gui.ResetOnSpawn = false

-- Fullscreen Frame
local frame = Instance.new("Frame")
frame.Size = UDim2.new(1, 0, 1, 0) -- full layar
frame.Position = UDim2.new(0, 0, 0, 0)
frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- hitam
frame.BackgroundTransparency = 0 -- tidak transparan
frame.Active = true
frame.Selectable = false
frame.Parent = gui

-- Text Label
local label = Instance.new("TextLabel")
label.Size = UDim2.new(1, 0, 1, 0)
label.Position = UDim2.new(0, 0, 0, 0)
label.BackgroundTransparency = 1
label.Text = "SCRIPT SEDANG MAINTENANCE\nNANTI BISA SCRIPT NYA"
label.TextColor3 = Color3.fromRGB(255, 255, 255) -- putih
label.TextScaled = true
label.Font = Enum.Font.SourceSansBold
label.Parent = frame

-- Mencegah klik ke belakang GUI
frame.InputBegan:Connect(function(input)
    input:Capture()
end)
