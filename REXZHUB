local current

local function loadQuestion()

current = questions[math.random(1,#questions)]

quizText.Text = "Quiz "..quizLevel.."\n"..current.q

A.Text = "A. "..current.a
B.Text = "B. "..current.b
C.Text = "C. "..current.c

end

local function check(ans)

if ans == current.correct then

score += 1
streak += 1
quizLevel += 1

scoreLabel.Text = "Score: "..score.." | Streak: "..streak

if quizLevel > 100 then
quizPanel.Visible = false
victory.Visible = true
return
end

quizText.Text = "Correct! Force "..quizLevel
task.wait(1)

loadQuestion()

else

quizText.Text = "Wrong!"

task.wait(1)

-- RESET SCORE
score = 0
streak = 0
quizLevel = 1

scoreLabel.Text = "Score: 0 | Streak: 0"

quizPanel.Visible = false
quizOpen = false

end

end

